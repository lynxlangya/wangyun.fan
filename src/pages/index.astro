          <button class="sw" data-theme-btn="auto" aria-label="auto" aria-pressed="false"><span class="face face-auto"></span></button>
          <button class="sw" data-theme-btn="light" aria-label="light" aria-pressed="false"><span class="face face-light"></span></button>
