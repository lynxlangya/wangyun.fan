<!doctype html>
<html lang="zh-CN" data-theme="auto">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>王雲帆 · Wang Yunfan</title>
<meta name="color-scheme" content="light dark">
<link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
<link rel="alternate icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='7' fill='%23fafaf7'/%3E%3Crect x='12.5' y='9' width='3.2' height='13' fill='%230e0e0c'/%3E%3Ccircle cx='21.5' cy='21' r='1.7' fill='%231d4ed8'/%3E%3C/svg%3E">
