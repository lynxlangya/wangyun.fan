<script is:inline>
  (function(){
    try{
      var saved = localStorage.getItem('wf.theme') || 'auto';
      var root = document.documentElement;
      root.setAttribute('data-theme', saved);
      var sysDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      var effective = saved === 'auto' ? (sysDark ? 'dark' : 'light') : saved;
      root.setAttribute('data-effective', effective);
    }catch(e){}
  })();
</script>

<style>
  :root,
  html[data-effective="light"]{
    --bg:        #fafaf7;
    --bg-2:      #f3f1ea;
    --ink:       #0e0e0c;
    --ink-soft:  #2a2a26;
    --muted:     #8a8a82;
    --muted-2:   #b6b5ad;
    --rule:      #e5e3dc;
    --accent:    #1d4ed8;
    --grain:     rgba(0,0,0,.018);
    --overlay:   rgba(250,250,247,.86);
    --shadow:    0 1px 0 rgba(0,0,0,.02), 0 8px 24px -12px rgba(0,0,0,.10);
  }
  html[data-effective="dark"]{
    --bg:        #111110;
    --bg-2:      #1a1a17;
    --ink:       #ecebe3;
    --ink-soft:  #cbc9bf;
    --muted:     #807e76;
    --muted-2:   #56544e;
    --rule:      #292826;
    --accent:    #8ba8ff;
    --grain:     rgba(255,255,255,.020);
    --overlay:   rgba(17,17,16,.86);
    --shadow:    0 1px 0 rgba(0,0,0,.35), 0 12px 28px -14px rgba(0,0,0,.55);
  }
  :root{
    --mono: "IBM Plex Mono", ui-monospace, "SFMono-Regular", Menlo, Consolas,
            "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", monospace;
    --serif: "IBM Plex Serif", "Songti SC", "STSong", Georgia, serif;
    --ease: cubic-bezier(.2,.6,.2,1);
  }

  *{box-sizing:border-box;margin:0;padding:0}
  html{-webkit-text-size-adjust:100%;scroll-behavior:smooth}
  body{
    background:var(--bg);color:var(--ink);
    font-family:var(--mono);font-size:14px;line-height:1.65;
    font-feature-settings:"ss01","ss02","calt","liga";
    -webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility;
    letter-spacing:-0.005em;
    transition: background-color .4s var(--ease), color .4s var(--ease);
  }
  ::selection{background:var(--accent);color:var(--bg)}
  body::before{
    content:"";position:fixed;inset:0;pointer-events:none;z-index:0;
    background-image: radial-gradient(var(--grain) 1px, transparent 1px);
    background-size: 3px 3px;mix-blend-mode:multiply;
  }
  html[data-effective="dark"] body::before{mix-blend-mode:screen}

  .menu-trigger{
    position:fixed;top:24px;right:28px;z-index:30;
    display:inline-flex;align-items:center;gap:10px;
    background:none;border:0;cursor:pointer;
    font-family:var(--mono);font-size:12px;
    color:var(--ink);letter-spacing:.04em;
    padding:6px 2px;
    -webkit-appearance:none;appearance:none;
  }
  .menu-trigger .lines{
    display:inline-flex;flex-direction:column;gap:3px;
    width:14px;height:10px;justify-content:center;
    transition: transform .35s var(--ease);
  }
  .menu-trigger .lines i{
    display:block;height:1px;background:currentColor;
    transition: width .35s var(--ease), transform .4s var(--ease), opacity .25s var(--ease);
  }
  .menu-trigger .lines i:nth-child(1){width:14px}
  .menu-trigger .lines i:nth-child(2){width:10px;align-self:flex-end}
  .menu-trigger:hover .lines i:nth-child(2){width:14px}
  .menu-trigger .label{
    position:relative;
    transition: opacity .25s var(--ease);
  }
  .menu-trigger .label::after{
    content:"";position:absolute;left:0;right:0;bottom:-3px;height:1px;
    background:currentColor;
    transform:scaleX(0);transform-origin:left;
    transition: transform .35s var(--ease);
  }
  .menu-trigger:hover .label::after{transform:scaleX(1)}
  @media (max-width:560px){
    .menu-trigger{top:16px;right:18px}
  }

  html.menu-open .menu-trigger .lines{transform:rotate(90deg)}
  html.menu-open .menu-trigger .lines i:nth-child(1){transform:translateY(2px) rotate(45deg);width:14px}
  html.menu-open .menu-trigger .lines i:nth-child(2){transform:translateY(-2px) rotate(-45deg);width:14px}

  .overlay{
    position:fixed;inset:0;z-index:20;
    background:var(--overlay);
    backdrop-filter: blur(18px) saturate(140%);
    -webkit-backdrop-filter: blur(18px) saturate(140%);
    opacity:0;pointer-events:none;
    transition: opacity .35s var(--ease);
  }
  html.menu-open .overlay{opacity:1;pointer-events:auto}

  .overlay-inner{
    position:absolute;inset:0;
    display:flex;flex-direction:column;
    max-width:680px;margin:0 auto;
    padding:96px 32px 56px;
  }
  @media (max-width:560px){
    .overlay-inner{padding:88px 22px 32px}
  }

  .overlay-label{
    position:absolute;top:30px;left:32px;
    font-size:11px;letter-spacing:.18em;text-transform:uppercase;
    color:var(--muted-2);
    opacity:0;transform:translateY(-4px);
    transition: opacity .4s var(--ease) .15s, transform .4s var(--ease) .15s;
  }
  html.menu-open .overlay-label{opacity:1;transform:none}
  @media (max-width:560px){.overlay-label{top:22px;left:22px}}

  .nav{
    list-style:none;
    margin-top:auto;margin-bottom:auto;
    display:flex;flex-direction:column;
    gap:2px;
  }
  .nav li{
    opacity:0;transform:translateY(10px);
    transition: opacity .5s var(--ease), transform .5s var(--ease);
  }
  html.menu-open .nav li{opacity:1;transform:none}
  html.menu-open .nav li:nth-child(1){transition-delay:.08s}
  html.menu-open .nav li:nth-child(2){transition-delay:.14s}
  html.menu-open .nav li:nth-child(3){transition-delay:.20s}
  html.menu-open .nav li:nth-child(4){transition-delay:.26s}
  html.menu-open .nav li:nth-child(5){transition-delay:.32s}
  html.menu-open .nav li:nth-child(6){transition-delay:.38s}

  .nav a{
    display:grid;
    grid-template-columns: 36px 1fr auto;
    align-items:baseline;
    gap:18px;
    text-decoration:none;color:var(--ink);
    padding:14px 0;
    border-bottom:1px solid var(--rule);
    font-family:var(--mono);
  }
  .nav a .num{
    font-size:11px;color:var(--muted-2);
    letter-spacing:.06em;
  }
  .nav a .lbl{
    font-size:32px;font-weight:500;
    letter-spacing:-0.02em;
    transition: transform .4s var(--ease), color .25s var(--ease);
  }
  .nav a .lbl .en{
    color:var(--muted);font-weight:400;
    margin-left:14px;font-size:14px;letter-spacing:.04em;
    text-transform:uppercase;
  }
  .nav a .arrow{
    color:var(--muted-2);font-size:16px;
    transition: transform .4s var(--ease), color .25s var(--ease), opacity .25s var(--ease);
    opacity:0;transform:translateX(-6px);
  }
  .nav a:hover .lbl{transform:translateX(8px);color:var(--accent)}
  .nav a:hover .arrow{opacity:1;transform:translateX(0);color:var(--accent)}
  @media (max-width:560px){
    .nav a{grid-template-columns:26px 1fr auto;gap:12px}
    .nav a .lbl{font-size:24px}
    .nav a .lbl .en{display:block;margin-left:0;margin-top:2px}
  }

  .overlay-foot{
    margin-top:48px;
    display:flex;justify-content:space-between;align-items:flex-end;
    gap:24px;flex-wrap:wrap;
    opacity:0;transform:translateY(8px);
    transition: opacity .5s var(--ease) .45s, transform .5s var(--ease) .45s;
  }
  html.menu-open .overlay-foot{opacity:1;transform:none}

  .theme{display:flex;flex-direction:column;gap:8px}
  .theme-label{
    font-size:10px;letter-spacing:.18em;text-transform:uppercase;
    color:var(--muted-2);
  }
  .swatches{display:flex;gap:6px;align-items:center}
  .sw{
    appearance:none;background:none;border:0;cursor:pointer;
    padding:0;margin:0;
    width:30px;height:30px;border-radius:50%;
    position:relative;
    display:inline-flex;align-items:center;justify-content:center;
    transition: transform .25s var(--ease);
  }
  .sw .face{
    width:18px;height:18px;border-radius:50%;
    border:1px solid var(--rule);
    transition: transform .35s var(--ease);
  }
  .sw .face-auto{background: linear-gradient(135deg, #fafaf7 0 50%, #111110 50% 100%)}
  .sw .face-light{background:#fafaf7}
  .sw .face-dark{background:#111110}
  .sw::after{
    content:"";position:absolute;inset:0;border-radius:50%;
    border:1px solid transparent;
    transition: border-color .25s var(--ease), transform .25s var(--ease);
  }
  .sw:hover{transform:translateY(-1px)}
  .sw:hover .face{transform:scale(1.08)}
  .sw[aria-pressed="true"]::after{border-color:var(--accent)}
  .sw-name{
    margin-left:10px;font-size:11px;
    color:var(--muted);letter-spacing:.12em;text-transform:uppercase;
    transition: color .2s var(--ease);
  }

  .contact{
    display:flex;flex-direction:column;gap:4px;
    text-align:right;
  }
  .contact .k{
    font-size:10px;letter-spacing:.18em;text-transform:uppercase;
    color:var(--muted-2);
  }
  .contact a{
    color:var(--ink);text-decoration:none;
    background-image: linear-gradient(var(--accent), var(--accent));
    background-repeat:no-repeat;background-size:0% 1px;
    background-position:100% 100%;
    transition: background-size .35s var(--ease), color .2s;
    padding-bottom:1px;
    font-size:13px;
  }
  .contact a:hover{background-size:100% 1px;color:var(--accent)}

  main{
    position:relative;z-index:1;
    max-width:680px;padding:96px 32px 160px;margin:0 auto;
  }
  @media (max-width:560px){
    main{padding:80px 22px 120px}body{font-size:13.5px}
  }

  .r{opacity:0;transform:translateY(8px);
     animation: rise .9s var(--ease) forwards}
  @keyframes rise{to{opacity:1;transform:none}}
  .d1{animation-delay:.05s}.d2{animation-delay:.16s}
  .d3{animation-delay:.28s}.d4{animation-delay:.42s}
  .d5{animation-delay:.56s}.d6{animation-delay:.70s}
  .d7{animation-delay:.84s}.d8{animation-delay:.98s}
  @media (prefers-reduced-motion:reduce){.r{opacity:1;transform:none;animation:none}}

  header{
    display:flex;align-items:flex-start;justify-content:space-between;
    gap:24px;
  }
  .id{display:flex;flex-direction:column;gap:6px}
  h1{
    font-family:var(--mono);font-weight:500;
    font-size:17px;letter-spacing:-0.01em;color:var(--ink);
  }
  h1 .en{color:var(--muted);font-weight:400;margin-left:2px}
  .caret{
    display:inline-block;width:7px;height:14px;
    background:var(--ink);transform:translateY(2px);margin-left:2px;
    animation:blink 1.05s steps(1) infinite;
  }
  @keyframes blink{50%{opacity:0}}
  .role{color:var(--muted);font-size:13px;letter-spacing:.01em}
  .role span{color:var(--ink-soft)}

  .status{
    display:inline-flex;align-items:center;gap:8px;
    font-size:12px;color:var(--muted);
    padding:4px 0 0;cursor:pointer;background:none;border:0;
    font-family:inherit;letter-spacing:inherit;
    appearance:none;-webkit-appearance:none;
    margin-right:60px;
  }
  @media (max-width:560px){.status{margin-right:50px}}
  .dot{
    position:relative;width:7px;height:7px;border-radius:50%;
    background:#00b21e;
    box-shadow:0 0 0 0 rgba(0,178,30,.45);
    animation: pulse 2.4s ease-out infinite;
  }
  html[data-effective="dark"] .dot{box-shadow:0 0 0 0 rgba(0,178,30,.5)}
  @keyframes pulse{
    0%{box-shadow:0 0 0 0 currentColor;opacity:.5}
    80%,100%{box-shadow:0 0 0 8px transparent}
  }
  .status:hover .status-text{color:var(--ink)}
  .status .status-text{transition: color .2s var(--ease)}

  .intro{
    margin-top:48px;font-size:15px;line-height:1.78;
    color:var(--ink-soft);max-width:62ch;
  }
  .intro p + p{margin-top:1em}
  .intro em{font-family:var(--serif);font-style:italic;color:var(--ink)}

  section{margin-top:64px;scroll-margin-top:80px}
  .sec-head{
    display:flex;align-items:baseline;justify-content:space-between;
    padding-bottom:10px;border-bottom:1px solid var(--rule);
    margin-bottom:18px;gap:16px;
  }
  .sec-head h2{
    font-size:11px;font-weight:500;
    letter-spacing:.18em;text-transform:uppercase;color:var(--ink);
  }
  .sec-head h2 .zh{color:var(--muted);margin-left:10px;letter-spacing:.06em}
  .sec-head .meta{
    font-size:11px;color:var(--muted-2);letter-spacing:.06em;white-space:nowrap;
  }

  .now{display:flex;flex-direction:column;gap:6px;font-size:14px}
  .now li{
    list-style:none;display:grid;grid-template-columns:18px 1fr;gap:4px;
    color:var(--ink-soft);
  }
  .now .mk{color:var(--muted-2)}
  .now strong{color:var(--ink);font-weight:500}
  .now em{font-family:var(--serif);font-style:italic;color:var(--ink)}

  .rows{display:flex;flex-direction:column}
  .row{
    display:grid;grid-template-columns:92px 1fr auto;
    gap:18px;padding:14px 0;
    border-bottom:1px dashed var(--rule);
    align-items:baseline;
    transition: background .25s var(--ease), padding .25s var(--ease);
  }
  .row:last-child{border-bottom:none}
  .row .when{color:var(--muted);font-size:12px;letter-spacing:.02em;padding-top:1px}
  .row .body{display:flex;flex-direction:column;gap:3px;min-width:0}
  .row .ttl{color:var(--ink);font-weight:500;font-size:14px}
  .row .ttl .at{color:var(--muted);font-weight:400}
  .row .desc{color:var(--muted);font-size:12.5px;line-height:1.55}
  .row .tag{
    font-size:10.5px;color:var(--muted-2);
    letter-spacing:.1em;text-transform:uppercase;
    padding-top:2px;white-space:nowrap;
  }
  .row:hover{
    background:linear-gradient(90deg, transparent, var(--bg-2) 6%, var(--bg-2) 94%, transparent);
    padding-left:8px;padding-right:8px;margin-left:-8px;margin-right:-8px;
  }
  @media (max-width:560px){
    .row{grid-template-columns:76px 1fr;gap:14px}
    .row .tag{grid-column:1 / -1;padding-top:2px}
  }
  .write .row:hover .tag{color:var(--accent)}

  .elsewhere{display:grid;grid-template-columns:repeat(2,1fr);gap:2px 28px}
  @media (max-width:560px){.elsewhere{grid-template-columns:1fr}}
  .elsewhere a{
    display:flex;justify-content:space-between;align-items:baseline;
    padding:11px 0;border-bottom:1px dashed var(--rule);
    color:var(--ink);text-decoration:none;font-size:13.5px;position:relative;
  }
  .elsewhere a .k{color:var(--muted);font-size:11px;letter-spacing:.1em;text-transform:uppercase}
  .elsewhere a .v{color:var(--ink-soft);transition: color .2s var(--ease), transform .25s var(--ease)}
  .elsewhere a:hover .v{color:var(--accent);transform:translateX(-2px)}
  .elsewhere a::after{
    content:"↗";position:absolute;right:-2px;top:50%;
    transform:translate(-6px,-50%);color:var(--accent);opacity:0;
    transition: opacity .25s var(--ease), transform .25s var(--ease);
    font-size:12px;
  }
  .elsewhere a:hover::after{opacity:1;transform:translate(0,-50%)}

  a.lnk{
    color:var(--ink);text-decoration:none;
    background-image: linear-gradient(var(--accent), var(--accent));
    background-repeat:no-repeat;background-size:0% 1px;background-position:0 100%;
    transition: background-size .35s var(--ease), color .2s;padding-bottom:1px;
  }
  a.lnk:hover{background-size:100% 1px;color:var(--accent)}

  footer{
    margin-top:80px;padding-top:18px;border-top:1px solid var(--rule);
    display:flex;justify-content:space-between;align-items:baseline;
    color:var(--muted-2);font-size:11px;letter-spacing:.06em;
  }
  footer kbd{
    font-family:var(--mono);font-size:10px;
    border:1px solid var(--rule);background:var(--bg);
    border-bottom-width:2px;padding:1px 5px;border-radius:3px;color:var(--muted);
  }

  html.menu-open body{overflow:hidden}
</style>
</head>
<body>

<button class="menu-trigger" id="menuBtn" aria-expanded="false" aria-controls="menuOverlay" type="button">
  <span class="lines" aria-hidden="true"><i></i><i></i></span>
  <span class="label" id="menuLabel">menu</span>
</button>

<div class="overlay" id="menuOverlay" role="dialog" aria-modal="true" aria-label="站点菜单">
  <div class="overlay-inner">
    <div class="overlay-label">wangyun.fan / index</div>

    <ul class="nav">
      <li><a href="#now" data-close><span class="num">01</span><span class="lbl">现在<span class="en">Now</span></span><span class="arrow">→</span></a></li>
