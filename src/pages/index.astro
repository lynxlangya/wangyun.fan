---
import HomeHeader from '../components/HomeHeader.astro';
import HomeIntro from '../components/HomeIntro.astro';
import HomeSection from '../components/HomeSection.astro';
import LinkGrid from '../components/LinkGrid.astro';
import NowList from '../components/NowList.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import SiteMenu from '../components/SiteMenu.astro';
import TimelineRow from '../components/TimelineRow.astro';
import {
  elsewhereLinks,
  investRows,
  nowItems,
  workRows,
  writingRows,
} from '../data/home';
---

<SiteLayout>
  <SiteMenu />

  <main>
    <HomeHeader />
    <HomeIntro />

    <HomeSection id="now" title="Now" zh="现在" meta="2026 年 5 月 · 杭州" delay="d3">
      <NowList items={nowItems} />
    </HomeSection>

    <HomeSection id="work" title="Work" zh="经历" meta="2017 — 至今" delay="d4">
      <div class="rows">
        {workRows.map((row) => <TimelineRow {...row} />)}
      </div>
    </HomeSection>

    <HomeSection id="invest" title="Invest" zh="投资" meta="天使 · 种子 · 约 30 笔" delay="d5">
      <div class="rows">
        {investRows.map((row) => <TimelineRow {...row} />)}
      </div>
    </HomeSection>

    <HomeSection id="writing" title="Writing" zh="写作" meta="文章 · 笔记" delay="d6" class="write">
      <div class="rows">
        {writingRows.map((row) => <TimelineRow {...row} />)}
      </div>
    </HomeSection>

    <HomeSection id="elsewhere" title="Elsewhere" zh="别处" meta="邮件最佳" delay="d7">
      <LinkGrid links={elsewhereLinks} />
    </HomeSection>

    <footer class="r d8">
      <div>wangyun.fan · v3.2</div>
      <div><kbd>M</kbd> menu · <kbd>T</kbd> theme</div>
    </footer>
  </main>
</SiteLayout>
