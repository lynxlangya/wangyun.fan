<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script is:inline>
(function(){
  const root = document.documentElement;
  const mq = window.matchMedia('(prefers-color-scheme: dark)');

  const btn = document.getElementById('menuBtn');
  const overlay = document.getElementById('menuOverlay');
  const label = document.getElementById('menuLabel');

  function openMenu(){
    root.classList.add('menu-open');
    btn.setAttribute('aria-expanded', 'true');
    label.textContent = 'close';
  }
  function closeMenu(){
    root.classList.remove('menu-open');
    btn.setAttribute('aria-expanded', 'false');
    label.textContent = 'menu';
  }
  btn.addEventListener('click', () => {
    root.classList.contains('menu-open') ? closeMenu() : openMenu();
  });
  overlay.addEventListener('click', (event) => {
    const link = event.target.closest('a[data-close]');
    if (link){
      closeMenu();
      return;
    }
    if (event.target === overlay) closeMenu();
  });
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && root.classList.contains('menu-open')) closeMenu();
  });

  const NAME = { auto:'AUTO', light:'LIGHT', dark:'DARK' };
  const themeName = document.getElementById('themeName');

  function applyTheme(theme, persist=true){
    if (!['auto','light','dark'].includes(theme)) theme = 'auto';
    root.setAttribute('data-theme', theme);
    const effective = theme === 'auto' ? (mq.matches ? 'dark' : 'light') : theme;
    root.setAttribute('data-effective', effective);
    themeName.textContent = NAME[theme];
    document.querySelectorAll('.sw').forEach((swatch) => {
      swatch.setAttribute('aria-pressed', swatch.dataset.themeBtn === theme ? 'true' : 'false');
    });
    if (persist){
      try{ localStorage.setItem('wf.theme', theme) }catch(e){}
    }
  }
  applyTheme(root.getAttribute('data-theme') || 'auto', false);

  document.querySelectorAll('.sw').forEach((swatch) => {
    swatch.addEventListener('click', () => applyTheme(swatch.dataset.themeBtn));
  });
  if (mq.addEventListener){
    mq.addEventListener('change', () => {
      if ((root.getAttribute('data-theme') || 'auto') === 'auto') applyTheme('auto', false);
    });
  }

  const status = document.getElementById('status');
  const statusText = document.getElementById('statusText');
  const messages = ['在旧金山 · 欢迎喝咖啡', '回复邮件中 · 稍后回来', '深夜写代码中'];
  let statusIndex = 0;
  if (status){
    status.addEventListener('click', () => {
      statusIndex = (statusIndex + 1) % messages.length;
      statusText.style.opacity = '0';
      setTimeout(() => {
        statusText.textContent = messages[statusIndex];
        statusText.style.opacity = '';
      }, 160);
    });
    statusText.style.transition = 'opacity .2s ease';
  }

  document.addEventListener('keydown', (event) => {
    if (event.target.matches('input,textarea,[contenteditable]')) return;
    if (event.key === 'm' || event.key === 'M'){
      root.classList.contains('menu-open') ? closeMenu() : openMenu();
    } else if (event.key === 't' || event.key === 'T'){
      const current = root.getAttribute('data-theme') || 'auto';
      const next = current === 'auto' ? 'light' : current === 'light' ? 'dark' : 'auto';
      applyTheme(next);
    }
  });
})();
</script>

