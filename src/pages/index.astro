<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script is:inline>
(function(){
  const root = document.documentElement;
  const mq = window.matchMedia('(prefers-color-scheme: dark)');
  const ICONS = { auto:'ic-auto', light:'ic-sun', dark:'ic-moon' };
  const LABELS = { auto:'AUTO', light:'LIGHT', dark:'DARK' };
  const ic = document.getElementById('themeIc');
  const lbl = document.getElementById('themeLbl');
  const btn = document.getElementById('themeBtn');

  function applyTheme(theme, persist=true){
    if (!['auto','light','dark'].includes(theme)) theme = 'auto';
    root.setAttribute('data-theme', theme);
    const effective = theme === 'auto' ? (mq.matches ? 'dark' : 'light') : theme;
    root.setAttribute('data-effective', effective);
    if (ic) ic.className = 'ic ' + ICONS[theme];
    if (lbl) lbl.textContent = LABELS[theme];
    if (persist){
      try{ localStorage.setItem('wf.theme', theme) }catch(e){}
    }
  }

  applyTheme(root.getAttribute('data-theme') || 'auto', false);
  if (btn){
    btn.addEventListener('click', () => {
      const cur = root.getAttribute('data-theme') || 'auto';
      applyTheme(cur === 'auto' ? 'light' : cur === 'light' ? 'dark' : 'auto');
    });
  }
  if (mq.addEventListener){
    mq.addEventListener('change', () => {
      if ((root.getAttribute('data-theme') || 'auto') === 'auto') applyTheme('auto', false);
    });
  }

  const status = document.getElementById('status');
  if (status){
    status.addEventListener('click', () => {
      const cur = status.getAttribute('data-flip') === '1';
      status.setAttribute('data-flip', cur ? '0' : '1');
    });
  }

  document.addEventListener('keydown', (event) => {
    if (event.target && event.target.matches('input,textarea,[contenteditable]')) return;
    if (event.key === 't' || event.key === 'T'){
      btn && btn.click();
    }
  });
})();
</script>

